generator client {
  	provider = "prisma-client-js"
	output   = "../node_modules/.prisma/client"
}

datasource db {
  	provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("user")
  
  // Profile fields
  displayName String?
  bio         String?

  // Tenant Relationship
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  
  createdAt DateTime @default(now())
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  users     User[]
  createdAt DateTime @default(now())
}
