generator client {
  	provider = "prisma-client-js"
	output   = "../node_modules/.prisma/client"
}

datasource db {
  	provider = "postgresql"
}

model User {
	id        String   @id @default(uuid())
	email     String   @unique
	password  String
	role      String @default("user")
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
}